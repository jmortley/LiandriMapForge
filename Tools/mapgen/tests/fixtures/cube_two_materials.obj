# MapForgeBridge multi-material import fixture: a 100uu cube whose six faces
# are split into two usemtl groups (M_CubeA = +Z/+X/+Y, M_CubeB = -Z/-X/-Y).
# Regression guard for MTL-sidecar staging: with the .mtl staged next to the
# temp OBJ this imports as TWO material slots; without it, one. 12 triangles.
# NOT the Andok acceptance asset.
mtllib cube_two_materials.mtl
o TwoMatCube
v -50.0 -50.0 -50.0
v  50.0 -50.0 -50.0
v  50.0  50.0 -50.0
v -50.0  50.0 -50.0
v -50.0 -50.0  50.0
v  50.0 -50.0  50.0
v  50.0  50.0  50.0
v -50.0  50.0  50.0
vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0
vn  0.0  0.0  1.0
vn  0.0  0.0 -1.0
vn  1.0  0.0  0.0
vn -1.0  0.0  0.0
vn  0.0  1.0  0.0
vn  0.0 -1.0  0.0
usemtl M_CubeA
f 5/1/1 6/2/1 7/3/1
f 5/1/1 7/3/1 8/4/1
f 2/1/3 3/2/3 7/3/3
f 2/1/3 7/3/3 6/4/3
f 4/1/5 8/2/5 7/3/5
f 4/1/5 7/3/5 3/4/5
usemtl M_CubeB
f 1/1/2 4/2/2 3/3/2
f 1/1/2 3/3/2 2/4/2
f 1/1/4 5/2/4 8/3/4
f 1/1/4 8/3/4 4/4/4
f 1/1/6 2/2/6 6/3/6
f 1/1/6 6/3/6 5/4/6
